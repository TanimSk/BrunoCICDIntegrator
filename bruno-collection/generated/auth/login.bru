meta {
  name: Login with Email and Password
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/rest-auth/login/
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "user@example.com",
    "password": "StrongPassword123"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
